n = int(input())
size = n-1
matrix = [[0]*size for _ in range(size)]
for layer in range((n//2)):
    value = layer + 1
    for j in range(layer,size-layer):
        matrix[layer][j] = value
    for j in range(layer,size-layer):
        matrix[size-layer-1][j] = value
    for i in range(layer,size-layer):
        matrix[i][layer] = value
    for i in range(layer,size-layer):
        matrix[i][size-layer-1] = value
    for row in matrix:
        print(*row)
#本质上是“按层填矩阵“
