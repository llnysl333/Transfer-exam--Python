digits = "0123456789ABCDEF"
num_str = input().strip()
base = int(input())
precision = 10
def convert_int_part(n,base):
    if n == 0:
        return "0"
    res = []
    while n > 0:
        res.append(digits[n % base])
        n //= base
    res.reverse()
    return "".join(res)
def convert_frac_part(frac_str,base,precision):
    if frac_str == "":
        return ""
    numerator = int(frac_str)
    denominator = 10**len(frac_str)
    res = []
    for _ in range(precision):
        if numerator == 0:
            break
        numerator *= base
        res.append(digits[numerator//denominator])
        numerator %= denominator
    return "".join(res)
if "." in num_str:
    int_str,frac_str = num_str.split(".")
else:
    int_str = num_str
    frac_str = ""
int_part = int(int_str)
int_res = convert_int_part(int_part,base)
frac_res = convert_frac_part(frac_str,base,precision)
if frac_res == "":
    print(int_res)
else:
    print(int_res + "." + frac_res)
