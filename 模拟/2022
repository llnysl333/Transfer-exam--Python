#05
m,n = map(int,input().split())
matrix = []
for _ in range(m):
    row = list(map(int,input().split()))
    matrix.append(row)
top = 0
bottom = m-1
left = 0
right = n-1
ans = []
while top<=bottom and left<=right:
    for a in range(left,right+1):
        ans.append(matrix[top][a])
    top += 1
    for b in range(top,bottom+1):
        ans.append(matrix[b][right])
    right -=1
    if top <= bottom:
        for c in range(right,left-1,-1):
            ans.append(matrix[bottom][c])
        bottom -= 1
    if left <= right:
        for d in range(bottom,top-1,-1):
            ans.append(matrix[d][left])
        left += 1
print(*ans)