l,r = map(int,input().split())
def is_prime(x):
    if x<2:
        return False
    for i in range(2,int(x**0.5)+1):
        if x%i == 0:
            return False
    return True
def is_pure_prime(x):
    s = str(x)
    for i in range(len(s)-1):
        x = int(s[i:])
        if not is_prime(x):
            return False
    return True
for i in range(l,r+1):
    if is_pure_prime(i):
        print(i)
