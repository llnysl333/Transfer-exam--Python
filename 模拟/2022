L,R = map(int,input().split())
def is_prime(x):
    if x<2:
        return False
    for i in range(2,int(x**0.5)+1):
        if x % i == 0:
            return False
    return True
def is_pureprime(x):
    if not is_prime(x):
        return False
    s=str(x)
    for i in range(len(s)):
        x=s[i:]#x = int(s[i:])
        if is_prime(x):#if not is_prime(x)
            return False
    return True
for i in range(L,R+1):
    if is_pureprime(i):
        print(i)
