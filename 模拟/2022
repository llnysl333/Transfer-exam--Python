digits = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
def convert_int(x,n):
    if x==0:
        return "0"
    res=[]
    while x>0:
        res.append(digits[x%n])
        x //= n
    return "".join(res[::-1])
#---------------------------------------------------------------
def convert_little(x,n):
    if x == 0:
        return "0"
    res=[]
    while x>0:
        res.append(int(x))
        x *= n
        x -= int(x)
    return "".join(res)
