def H_prime(x):
    if x%4 != 1:
        return False
    if x<2:
        return False
    for i in range(2,int(x**0.5)+1):
        if x%i == 0:
            return False
    return True
res = []
for i in range(2,150):
    for j in range(i,150//2):
        if H_prime(i) and H_prime(j) and i*j <= 150:
            res.append(i*j)
res.sort()
for i in res:
    print(i)
