n = int(input())
if n >= 0:
    res = bin(n)[2:].zfill(16)
else:
    n = abs(n)
    n = list(bin(n)[2:].zfill(15))
    for i in range(len(n)):
        if n[i] == '0':
            n[i] = '1'
        else:
            n[i] = '0'
    ans = int('1'+''.join(n),2)+1
    res = bin(ans)[2:] 
print(res)
