#03
v = int(input())
n = 0
while n*(n-1)//2 < v:
    n += 1
res = []
remain = v
left = 1
right = n
while left<right:
    diff = right-left
    if remain > diff:
        res.append(chr(ord('a')+right-1))
        remain -= diff
        right -= 1
    else:
        res.append(chr(ord('a')+left-1))
        left += 1
        res.append(chr(ord('a')+left-1))
print("".join(res))
