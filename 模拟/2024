#04
n,k = map(int,input())
res = []
for i in range(n):
    Hi,Wi = map(int,input().split())
    res.append((Hi,Wi))
def can_cut(side):
    count = 0
    for Hi,Wi in res:
        count += (Hi//side)*(Wi//side)
    return count >= k
left = 1
right = max(max(Hi,Wi) for Hi,Wi in res)
ans = 1
while left <= right:
    mid = (left+right)//2
    if can_cut(mid):
        left = mid+1
        ans = mid
    else:
        right = mid-1
print(ans)
