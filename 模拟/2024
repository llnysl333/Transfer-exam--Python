def is_prime(x):
    if x < 2:
        return False
    for i in range(2,int(x**0.5)+1):
        if x%i == 0:
            return False
    return True
d = 30
while True:
    for num1 in range(2,10000):
        for i in range(10):
            if not is_prime(num1 + i*d):
                break
        else:
            print(d)
            exit()
    d += 30