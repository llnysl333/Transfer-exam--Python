n,k = map(int,input().split())
chocolates = []
for _ in range(n):
    h,w = map(int,input().split())
    chocolates.append(h,w)
def can_cut(side):
    count = 0
    for h,w in chocolates:
        count += (h//side)*(w//side)
    return count >= k
left = 1
right = max(max(h,w) for h,w in chocolates)
ans = 1
while left <= right:
    mid = (left + right)//2
    if can_cut(mid):
        ans = mid
        left = mid + 1
    else:
        right = mid - 1
print(ans)
